# MISTRAL_API_KEY: Required for Mistral AI API calls.
# Configure this for local development and Vercel deployment.
MISTRAL_API_KEY="YOUR_MISTRAL_API_KEY"

# APP_URL: The URL where this app is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3000"

# VITE_GA_ID: Google Analytics 4 Measurement ID
# Format: G-XXXXXXXXXX
# Configure this for Vercel deployment to enable Google Analytics tracking
# Vite automatically exposes variables with VITE_ prefix to the client
VITE_GA_ID="G-YOUR_GA_MEASUREMENT_ID"
